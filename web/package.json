{
  "name": "engelos-web",
  "version": "0.1.0",
  "private": true,
  "description": "engelOS frontend monorepo — shared UI, local (self-hosted) variant, cloud (SaaS) variant",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "pnpm --filter @engelos/local dev",
    "build": "pnpm --filter @engelos/local build",
    "preview": "pnpm --filter @engelos/local preview",
    "check": "pnpm -r --parallel check"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
